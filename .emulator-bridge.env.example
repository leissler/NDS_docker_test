# Optional host emulator bridge configuration.
# Copy to .emulator-bridge.env and adjust for your machine.

# Bridge settings
# NDS_BRIDGE_PORT=17778
# NDS_BRIDGE_BIND=0.0.0.0
# NDS_GDB_PORT=3333
# NDS_BRIDGE_GDB_PORT=3335

# Default emulator launched by the bridge:
# Supported: melonds
NDS_EMULATOR=melonds

# Debug note:
# Debug sessions use melonDS GDB stub on ARM9 port.
# Host launches default to 3333. Devcontainer launches default to 7333
# (to avoid host/container port-3333 collisions).
# For devcontainer attach, the host bridge exposes this on NDS_BRIDGE_GDB_PORT (default 3335).
# The bridge auto-toggles melonDS config before launch:
#   - debug: Gdb.Enabled=true, ARM9 BreakOnStartup=false, JIT.Enable=false
#   - run:   Gdb.Enabled=false

# Optional explicit emulator binary.
# If omitted, auto-discovery is used.

# macOS melonDS:
# NDS_EMULATOR_BIN=/Applications/melonDS.app/Contents/MacOS/melonDS

# Linux melonDS:
# NDS_EMULATOR_BIN=/usr/bin/melonds

# WSL2 using Windows melonDS install:
# NDS_EMULATOR_BIN=/mnt/c/Program Files/melonDS/melonDS.exe

# Windows native PowerShell/CMD:
# NDS_EMULATOR_BIN=C:\\Program Files\\melonDS\\melonDS.exe
