# Keep the repository tight: ignore everything by default, then whitelist
# project inputs and tooling.
*
!/.gitignore

# Core build files
!/Dockerfile
!/build.py
!/Makefile
!/README.md
!/.clangd

# Devcontainer + VSCode workflow
!/.devcontainer/
!/.devcontainer/**
!/.vscode/
!/.vscode/c_cpp_properties.json
!/.vscode/tasks.json
!/.vscode/launch.json
!/.emulator-bridge.env.example

# Local build helper module
!/architectds/
!/architectds/**

# Project source and content (artists/devs can add new files here)
!/source/
!/source/**
!/assets/
!/assets/**
/assets/**/*.blend
/assets/**/*.dsmparam

# Emulator launcher/config helpers
!/tools/
!/tools/**
!/scripts/
!/scripts/**

# Ignore generated artifacts and local junk
/.git/
/build/
/output/
/build.ninja
/.ninja_deps
/.ninja_log
/.debug-logs/
/*.nds
/architectds/__pycache__/
/scripts/__pycache__/
/tools/__pycache__/
/.devcontainer/nds-bridge-init.log
**/.DS_Store
